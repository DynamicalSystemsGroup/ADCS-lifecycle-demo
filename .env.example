# .env.example — copy to .env and edit. Loaded by the pipeline runner
# via os.environ (no dotenv lib in scope). All variables have defaults;
# the file documents them in one place.

# --- Flexo MMS (storage backend) ----------------------------------------
# Pre-issued bearer token. Required to push to a remote Flexo instance.
# Leave empty to use the login flow against FLEXO_AUTH_URL.
FLEXO_TOKEN=
# Base URL of the Flexo Layer 1 service. Default = Planetary Utilities
# starforge instance.
FLEXO_URL=https://try-layer1.starforge.app
# Login-flow auth (used when FLEXO_TOKEN is empty).
FLEXO_AUTH_URL=http://localhost:8082
FLEXO_USER=user01
FLEXO_PASS=password1
# Org + repo where the pipeline persists. The default cleanly nests
# under <org>/lifecycle so multiple instances of the demo coexist.
FLEXO_ORG=adcs-demo
FLEXO_REPO=lifecycle
# Timeouts (seconds). FLEXO_TIMEOUT is generous because INSERT DATA
# can be slow on a shared remote; FLEXO_PROBE_TIMEOUT is fast by design.
FLEXO_TIMEOUT=180
FLEXO_PROBE_TIMEOUT=10
# Optional per-run branch prefix for multi-run isolation (WP4 c14).
# Default empty = single canonical state. Example value: cert/2026-06-12-001/
FLEXO_BRANCH_PREFIX=

# --- Transaction-log store (fourth service: CouchDB) -------------------
# Off by default. Set ADCS_TXNLOG_ENABLED=1 to opt in (requires
# tools/start-services.sh to have brought up the local CouchDB).
ADCS_TXNLOG_ENABLED=0
ADCS_TXNLOG_URL=http://localhost:5984
ADCS_TXNLOG_DB=adcs-txnlogs
ADCS_TXNLOG_USER=adcs
ADCS_TXNLOG_PASSWORD=adcs

# --- Organizational auspices (WP4 c6, per substrate) --------------------
# Each substrate carries the auspices of the org that actually operates
# it. NOTE: FLEXO_ORG above is the Flexo MMS org *slug* (a REST path
# segment), unrelated to these auspices IRIs.
#
# Compute substrate: who runs the pipeline (operating) and who operates
# the machine the analysis runs on (hosting). Both default to
# urn:adcs:org:local-operator; hosting defaults to operating when unset.
ADCS_OPERATING_ORG_IRI=urn:adcs:org:local-operator
ADCS_OPERATING_ORG_LABEL=Local Operator
ADCS_OPERATING_ORG_DESCRIPTION=Single-operator workstation; no hosted substrate.
# ADCS_HOSTING_ORG_IRI=urn:adcs:org:local-operator
# ADCS_HOSTING_ORG_LABEL=Local Operator
# ADCS_HOSTING_ORG_DESCRIPTION=Operator of the local compute substrate.
#
# Flexo substrate: who operates the remote Flexo MMS instance. Unset =
# unknown (the service node is emitted without an auspices edge).
# ADCS_FLEXO_HOSTING_ORG_IRI=urn:adcs:org:planetary-utilities
# ADCS_FLEXO_HOSTING_ORG_LABEL=Planetary Utilities
# ADCS_FLEXO_HOSTING_ORG_DESCRIPTION=Hosting auspices for the Starforge Flexo MMS substrate.
#
# Txnlog substrate: who operates the transaction-log store. Defaults to
# the compute-substrate hosting org (the demo's CouchDB runs locally).
# ADCS_TXNLOG_HOSTING_ORG_IRI=urn:adcs:org:local-operator
# ADCS_TXNLOG_HOSTING_ORG_LABEL=Local Operator
# ADCS_TXNLOG_HOSTING_ORG_DESCRIPTION=Operator of the transaction-log substrate.
