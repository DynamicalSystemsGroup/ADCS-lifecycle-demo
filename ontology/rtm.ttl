@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix earl: <http://www.w3.org/ns/earl#> .
@prefix gsn: <https://w3id.org/OntoGSN/ontology#> .
@prefix omg-sysml: <http://www.omg.org/spec/SysML/20240501/> .
@prefix oslc_qm: <http://open-services.net/ns/qm#> .
@prefix oslc_rm: <http://open-services.net/ns/rm#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rtm: <http://example.org/ontology/rtm#> .
@prefix sysml: <https://www.omg.org/spec/SysML/2.0/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

rtm: a owl:Ontology ;
    dcterms:description """Thin application ontology assembling PROV-O, EARL,
        OntoGSN, P-PLAN, OSLC RM/QM, and the OMG SysMLv2 OWL rendering.
        Contributes convenience handles, content-addressing properties, and
        the closure-rule suite. Introduces no novel epistemic vocabulary —
        adequacy and sufficiency are gsn:Assumption and gsn:Justification.""" ;
    dcterms:license <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:title "RTM Integration Ontology" ;
    owl:imports oslc_qm:,
        oslc_rm:,
        <http://purl.org/net/p-plan>,
        earl:,
        <http://www.w3.org/ns/prov-o>,
        <https://w3id.org/OntoGSN/ontology> .

rtm:ComputationEngine a owl:Class ;
    rdfs:label "Computation Engine" ;
    rdfs:subClassOf prov:SoftwareAgent .

rtm:DigestMatchAssertion a owl:Class ;
    rdfs:label "Image-digest reproduction assertion" ;
    rdfs:comment "Automated outcome of an image-digest reproduction check (compute.reproduce). earl:mode is always earl:automatic." ;
    rdfs:subClassOf earl:Assertion,
        prov:Activity .

rtm:Engineer a owl:Class ;
    rdfs:label "Engineer" ;
    rdfs:subClassOf earl:Assertor,
        prov:Agent .

rtm:NumericalSimulation a owl:Class ;
    rdfs:label "Numerical Simulation" ;
    rdfs:subClassOf prov:Activity .

rtm:SimulationResult a owl:Class ;
    rdfs:label "Simulation Result" ;
    rdfs:comment "Numerical simulation output produced by scipy." ;
    rdfs:subClassOf rtm:Evidence .

rtm:SymbolicAnalysis a owl:Class ;
    rdfs:label "Symbolic Analysis" ;
    rdfs:subClassOf prov:Activity .

rtm:attestationMode a owl:ObjectProperty ;
    rdfs:label "attestation mode" ;
    rdfs:comment "earl:manual (interactive), earl:semiAuto (--auto with text), earl:automatic (CI sign-off)." ;
    rdfs:domain rtm:Attestation ;
    rdfs:subPropertyOf earl:mode .

rtm:baseImageDigest a owl:DatatypeProperty ;
    rdfs:label "Digest of the FROM image resolved at build time" ;
    rdfs:domain rtm:DockerImage ;
    rdfs:range xsd:string .

rtm:buildContextHash a owl:DatatypeProperty ;
    rdfs:label "SHA-256 over a sorted manifest of build-context file hashes" ;
    rdfs:domain rtm:DockerImage ;
    rdfs:range xsd:string .

rtm:containerId a owl:DatatypeProperty ;
    rdfs:label "Container ID (runtime)" ;
    rdfs:domain rtm:DockerContainer ;
    rdfs:range xsd:string .

rtm:contentHash a owl:DatatypeProperty ;
    rdfs:label "content hash" ;
    rdfs:comment "SHA-256 hash of the evidence artifact content." ;
    rdfs:domain rtm:Evidence ;
    rdfs:range xsd:string .

rtm:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from" ;
    rdfs:comment "Subsystem requirement derived from a parent (system-level) requirement." ;
    rdfs:domain sysml:RequirementDefinition ;
    rdfs:range sysml:RequirementDefinition .

rtm:dockerfileHash a owl:DatatypeProperty ;
    rdfs:label "SHA-256 of the Dockerfile bytes used at build" ;
    rdfs:domain rtm:DockerImage ;
    rdfs:range xsd:string .

rtm:documentRef a owl:DatatypeProperty ;
    rdfs:label "URI of the evidence document in its backing store" ;
    rdfs:domain rtm:Evidence ;
    rdfs:range xsd:anyURI .

rtm:evidenceMethod a owl:ObjectProperty ;
    rdfs:label "evidence method" ;
    rdfs:domain rtm:Evidence ;
    rdfs:range rtm:EvidenceMethod .

rtm:flexoRecord a owl:ObjectProperty ;
    rdfs:label "URI into the storage backend (where this image's record lives)" ;
    rdfs:domain rtm:DockerImage .

rtm:followedProcedure a owl:ObjectProperty ;
    rdfs:label "followed procedure" ;
    rdfs:comment "The SOP / checklist the attester followed (content-hashable plan instance)." ;
    rdfs:domain rtm:Attestation ;
    rdfs:range prov:Plan ;
    rdfs:subPropertyOf prov:hadPlan .

rtm:gitCommit a owl:DatatypeProperty ;
    rdfs:label "git commit" ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string .

rtm:gitRef a owl:DatatypeProperty ;
    rdfs:label "git+URI of source at build commit" ;
    rdfs:domain rtm:DockerImage ;
    rdfs:range xsd:anyURI .

rtm:hasEvidence a owl:ObjectProperty ;
    rdfs:label "has evidence" ;
    rdfs:comment "Evidence artifacts the engineer reviewed when making this attestation." ;
    rdfs:domain rtm:Attestation ;
    rdfs:range rtm:Evidence ;
    rdfs:subPropertyOf prov:used,
        gsn:supportedBy .

rtm:hasOutcome a owl:ObjectProperty ;
    rdfs:label "has outcome" ;
    rdfs:comment """The EARL outcome of the attestation. Range values:
        earl:passed, earl:failed, earl:cantTell, earl:inapplicable,
        earl:untested. cantTell and inapplicable are first-class in EARL
        and fit the demo's 'models are imperfect' framing better than
        a binary verify/not-verify.""" ;
    rdfs:domain rtm:Attestation ;
    rdfs:subPropertyOf earl:outcome .

rtm:imageLabel a owl:DatatypeProperty ;
    rdfs:label "Image repo/tag (e.g., adcs-compute:latest)" ;
    rdfs:domain rtm:DockerImage ;
    rdfs:range xsd:string .

rtm:modelHash a owl:DatatypeProperty ;
    rdfs:label "model hash" ;
    rdfs:comment "SHA-256 hash of the structural model at the time evidence was produced." ;
    rdfs:domain rtm:Evidence ;
    rdfs:range xsd:string .

rtm:operatedBy a owl:ObjectProperty ;
    rdfs:label "host operated by organization" ;
    rdfs:domain prov:Location ;
    rdfs:range prov:Organization ;
    rdfs:subPropertyOf prov:wasAttributedTo .

rtm:proofHash a owl:DatatypeProperty ;
    rdfs:label "proof hash" ;
    rdfs:comment "SHA-256 hash of proof script content + model hash. Used by the re-verification closure check." ;
    rdfs:domain rtm:ProofArtifact ;
    rdfs:range xsd:string .

rtm:resultSummary a owl:DatatypeProperty ;
    rdfs:label "result summary" ;
    rdfs:domain rtm:Evidence ;
    rdfs:range xsd:string .

rtm:sourceFile a owl:DatatypeProperty ;
    rdfs:label "source file" ;
    rdfs:domain rtm:Evidence ;
    rdfs:range xsd:string .

rtm:transactionId a owl:DatatypeProperty ;
    rdfs:label "Service-invocation transaction ID" ;
    rdfs:domain prov:Activity ;
    rdfs:range xsd:string .

rtm:violationCount a owl:DatatypeProperty ;
    rdfs:label "Number of violations summarized by this closure assertion" ;
    rdfs:domain rtm:ClosureRuleAssertion ;
    rdfs:range xsd:nonNegativeInteger .

sysml:AttributeUsage a owl:Class ;
    owl:equivalentClass omg-sysml:AttributeUsage .

sysml:PartDefinition a owl:Class ;
    owl:equivalentClass omg-sysml:PartDefinition .

sysml:PartUsage a owl:Class ;
    owl:equivalentClass omg-sysml:PartUsage .

sysml:RequirementUsage a owl:Class ;
    owl:equivalentClass omg-sysml:RequirementUsage .

sysml:SatisfyRequirementUsage a owl:Class ;
    owl:equivalentClass omg-sysml:SatisfyRequirementUsage .

sysml:declaredName a owl:DatatypeProperty ;
    owl:equivalentProperty omg-sysml:declaredName .

sysml:ownedRelationship a owl:ObjectProperty ;
    owl:equivalentProperty omg-sysml:ownedRelationship .

sysml:text a owl:DatatypeProperty ;
    owl:equivalentProperty omg-sysml:text .

rtm:ClosureRuleAssertion a owl:Class ;
    rdfs:label "SHACL closure-rule assertion" ;
    rdfs:comment "Automated outcome of a SHACL closure-rule check (Stage 6.5). earl:mode is always earl:automatic." ;
    rdfs:subClassOf earl:Assertion,
        prov:Activity .

rtm:DockerContainer a owl:Class ;
    rdfs:label "Docker container" ;
    rdfs:comment "A transient materialization of an rtm:DockerImage; one per run, identified by the runtime container ID. Distinct from prov:Location (the host machine) and prov:SoftwareAgent (the executor that ran the work)." ;
    rdfs:subClassOf prov:Entity .

rtm:EvidenceMethod a owl:Class ;
    rdfs:label "Evidence Method" ;
    rdfs:comment "Classification of how an evidence artifact was produced (Analysis / Simulation / FormalProof)." .

rtm:ProofArtifact a owl:Class ;
    rdfs:label "Proof Artifact" ;
    rdfs:comment "Symbolic proof produced by SymPy (chain of independently re-verifiable lemmas)." ;
    rdfs:subClassOf rtm:Evidence .

rtm:addressedBy a owl:ObjectProperty ;
    rdfs:label "addressed by" ;
    rdfs:domain sysml:RequirementDefinition ;
    rdfs:range rtm:Evidence ;
    owl:inverseOf rtm:addresses .

rtm:addresses a owl:ObjectProperty ;
    rdfs:label "addresses" ;
    rdfs:comment """Structural intent link from evidence to the requirement
        it was produced to evaluate. NOT an attestation — only records that
        the artifact was constructed in service of this requirement.""" ;
    rdfs:domain rtm:Evidence ;
    rdfs:range sysml:RequirementDefinition ;
    owl:inverseOf rtm:addressedBy .

rtm:attestedBy a owl:ObjectProperty ;
    rdfs:label "attested by" ;
    rdfs:domain sysml:RequirementDefinition ;
    rdfs:range rtm:Attestation ;
    owl:inverseOf rtm:attests .

rtm:attests a owl:ObjectProperty ;
    rdfs:label "attests" ;
    rdfs:comment "The requirement this attestation makes a claim about." ;
    rdfs:domain rtm:Attestation ;
    rdfs:range sysml:RequirementDefinition ;
    rdfs:subPropertyOf oslc_qm:validatesRequirement,
        earl:test ;
    owl:inverseOf rtm:attestedBy .

omg-sysml:AttributeUsage a owl:Class .

omg-sysml:PartDefinition a owl:Class .

omg-sysml:PartUsage a owl:Class .

omg-sysml:RequirementDefinition a owl:Class .

omg-sysml:RequirementUsage a owl:Class .

omg-sysml:SatisfyRequirementUsage a owl:Class .

omg-sysml:declaredName a owl:DatatypeProperty .

omg-sysml:ownedRelationship a owl:ObjectProperty .

omg-sysml:text a owl:DatatypeProperty .

rtm:Attestation a owl:Class ;
    rdfs:label "Attestation" ;
    rdfs:comment """Human judgment event linking a requirement to evidence
        under an adequacy assumption and a sufficiency justification.
        Semantically: an earl:Assertion (carries outcome + mode), a
        gsn:Strategy (argues the requirement via supporting solutions
        in context of assumptions and justifications), and a prov:Activity
        (provenance-tracked event in time).""" ;
    rdfs:subClassOf earl:Assertion,
        prov:Activity,
        gsn:Strategy .

rtm:DockerImage a owl:Class ;
    rdfs:label "Docker container image" ;
    rdfs:comment """Content-tracked Docker image. Every analysis activity
        that ran under --compute=docker has its evidence link back to a
        DockerImage via prov:wasDerivedFrom. The image's identity is
        rtm:contentHash (the runtime digest); reproducibility is anchored
        by rtm:dockerfileHash + rtm:buildContextHash + rtm:baseImageDigest
        which together pin the build inputs.""" ;
    rdfs:subClassOf prov:Entity .

sysml:RequirementDefinition a owl:Class ;
    rdfs:subClassOf oslc_rm:Requirement ;
    owl:equivalentClass omg-sysml:RequirementDefinition .

rtm:Evidence a owl:Class ;
    rdfs:label "Evidence" ;
    rdfs:comment """A computational artifact constituting a claim true
        within a model. Subclass of gsn:Solution (a leaf of the
        argument tree) and prov:Entity (provenance-tracked).""" ;
    rdfs:subClassOf prov:Entity,
        gsn:Solution .

